generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================= ENUMS =================
enum Role {
  OWNER
  MANAJER
  KASIR
  GUDANG
}

enum PaymentMethod {
  CASH
  QRIS
  CARD
}

enum POStatus {
  PENDING
  DIKIRIM
  DITERIMA
  CANCELLED
}

enum TrxStatus {
  PENDING
  PAID
}

enum BeanType {
  WHOLE_BEAN
  GROUND
}

enum StockLogType {
  PO_IN
  SALE
  RECONCILIATION
  ADJUSTMENT
}

// ================= MODELS =================

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(100)
  username     String?   @unique
  email        String   @unique @db.VarChar(100)
  passwordHash String   @map("password_hash")
  role         Role
  outlet       String    @default("Senopati")
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relasi sebagai pembuat data
  createdSuppliers        Supplier[]            @relation("SupplierCreatedBy")
  createdProducts         Product[]             @relation("ProductCreatedBy")
  createdPurchaseOrders   PurchaseOrder[]       @relation("POCreatedBy")
  cashierTransactions     Transaction[]         @relation("TrxCashier")
  createdStockLogs        StockLog[]            @relation("StockLogCreatedBy")
  createdReconciliations  StockReconciliation[] @relation("ReconCreatedBy")
  activityLogs            ActivityLog[]         @relation("UserActivityLog")

  @@map("users")
}

model Supplier {
  id           String   @id @default(uuid()) @db.Uuid
  supplierCode String   @unique @map("supplier_code") @db.VarChar(20)  
  name         String   @db.VarChar(150)
  picName      String   @map("pic_name") @db.VarChar(100)
  region       String   @db.VarChar(100)
  phone        String   @db.VarChar(20)
  email        String?  @db.VarChar(100)
  address      String?  @db.Text
  notes        String?  @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdById  String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relasi
  createdBy        User              @relation("SupplierCreatedBy", fields: [createdById], references: [id])
  supplierProducts SupplierProduct[]
  purchaseOrders   PurchaseOrder[]

  @@map("suppliers")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  sku          String   @unique @db.VarChar(20)
  name         String   @db.VarChar(150)
  type         BeanType
  variety      String?  @db.VarChar(50)
  sellPrice    Float    @map("sell_price") 
  stockKg      Float    @map("stock_kg")
  minStockKg   Float    @map("min_stock_kg")
  isActive     Boolean  @default(true) @map("is_active")
  createdById  String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relasi
  createdBy             User                  @relation("ProductCreatedBy", fields: [createdById], references: [id])
  supplierProducts      SupplierProduct[]
  poItems               POItem[]
  transactionItems      TransactionItem[]
  stockLogs             StockLog[]
  stockReconciliations  StockReconciliation[]

  @@map("products")
}

model SupplierProduct {
  id            String   @id @default(uuid()) @db.Uuid
  supplierId    String   @map("supplier_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  buyPricePerKg Float    @map("buy_price_per_kg")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relasi
  supplier Supplier @relation(fields: [supplierId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@map("supplier_products")
}

model PurchaseOrder {
  id          String    @id @default(uuid()) @db.Uuid
  poNumber    String    @unique @map("po_number") @db.VarChar(20)
  supplierId  String    @map("supplier_id") @db.Uuid
  status      POStatus  @default(PENDING)
  totalAmount Float     @default(0) @map("total_amount")
  notes       String?   @db.Text
  createdById String    @map("created_by") @db.Uuid
  receivedAt  DateTime? @map("received_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relasi
  supplier  Supplier @relation(fields: [supplierId], references: [id])
  createdBy User     @relation("POCreatedBy", fields: [createdById], references: [id])
  items     POItem[]

  @@map("purchase_orders")
}

model POItem {
  id            String @id @default(uuid()) @db.Uuid
  poId          String @map("po_id") @db.Uuid
  productId     String @map("product_id") @db.Uuid
  qtyKg         Float  @map("qty_kg")
  buyPricePerKg Float  @map("buy_price_per_kg")
  subtotal      Float

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@map("po_items")
}

model Transaction {
  id            String        @id @default(uuid()) @db.Uuid
  trxNumber     String        @unique @map("trx_number") @db.VarChar(20)
  paymentMethod PaymentMethod @map("payment_method")
  status        TrxStatus     @default(PENDING)
  totalAmount   Float         @default(0) @map("total_amount")
  totalCogs     Float         @default(0) @map("total_cogs")
  grossProfit   Float         @default(0) @map("gross_profit")
  cashierId     String        @map("cashier_id") @db.Uuid
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relasi
  cashier User              @relation("TrxCashier", fields: [cashierId], references: [id])
  items   TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id             String @id @default(uuid()) @db.Uuid
  transactionId  String @map("transaction_id") @db.Uuid
  productId      String @map("product_id") @db.Uuid
  qtyKg          Float  @map("qty_kg")
  sellPricePerKg Float  @map("sell_price_per_kg")
  buyPricePerKg  Float  @map("buy_price_per_kg")
  subtotal       Float
  profit         Float

  transaction Transaction @relation(fields: [transactionId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])

  @@map("transaction_items")
}

model StockLog {
  id            String       @id @default(uuid()) @db.Uuid
  productId     String       @map("product_id") @db.Uuid
  type          StockLogType
  qtyChange     Float        @map("qty_change")
  qtyBefore     Float        @map("qty_before")
  qtyAfter      Float        @map("qty_after")
  referenceId   String?      @map("reference_id") @db.Uuid 
  referenceType String?      @map("reference_type") @db.VarChar(50) 
  note          String?      @db.Text
  createdById   String       @map("created_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at")

  createdBy User    @relation("StockLogCreatedBy", fields: [createdById], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("stock_logs")
}

model StockReconciliation {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  systemQty   Float    @map("system_qty")
  physicalQty Float    @map("physical_qty")
  difference  Float
  reason      String   @db.Text
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy User    @relation("ReconCreatedBy", fields: [createdById], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("stock_reconciliations")
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  payload    Json?    
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation("UserActivityLog", fields: [userId], references: [id])

  @@map("activity_logs")
}